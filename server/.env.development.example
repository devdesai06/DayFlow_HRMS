PORT=5000
NODE_ENV=development
APP_NAME=Dayflow
MONGODB_URI=mongodb://127.0.0.1:27017/dayflow
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=Dayflow <no-reply@dayflow.local>
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_FOLDER=dayflow/avatars
DB_CONNECT_ATTEMPTS=10
DB_CONNECT_DELAY_MS=800
DB_SERVER_SELECTION_TIMEOUT_MS=8000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=200
ATT_LATE_AFTER_MIN=10
ATT_START_HOUR=10
ATT_START_MIN=0
ATT_END_HOUR=18
ATT_END_MIN=0
ATT_OVERTIME_AFTER_MIN=540
LEAVE_BAL_SICK=10
LEAVE_BAL_CASUAL=10
LEAVE_BAL_PAID=15
